# Copy to .env.local and adjust.

# Optional: Next.js dev rewrites only (see next.config.ts). The app now defaults the browser to
# http://127.0.0.1:8000 for API calls unless NEXT_PUBLIC_API_BASE_URL is set — you usually do not
# need BACKEND_URL unless you still use same-origin /api rewrites on purpose.
# BACKEND_URL=http://127.0.0.1:8000

# Optional: override API origin (production or non-default port, e.g. http://localhost:8002).
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
