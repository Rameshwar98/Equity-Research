APP_ENV=development
# Relative paths are resolved under the backend/ folder (next to app/), not uvicorn's cwd.
CACHE_DIR=./cache
# Durable portfolios + daily tracking (defaults to CACHE_DIR). On Render, point at a persistent disk:
# DATA_DIR=/var/data/equity
DATA_DIR=
DB_PATH=./cache/equity.db
# Set to true if you want the backend to persist cached price history + analysis runs in SQLite
persist_cache=false
# Comma-separated
# Include 127.0.0.1 if you open the app at http://127.0.0.1:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: controls cache freshness for analysis runs
ANALYSIS_TTL_SECONDS=1800
# Optional: peer comparison cache (list + FMP metadata per anchor); per-symbol meta reused across anchors
PEER_CACHE_TTL_SECONDS=86400
PEER_FMP_META_TTL_SECONDS=172800
# Optional: Financial Modeling Prep download parameters
FMP_PERIOD=2y
FMP_INTERVAL=1d

# Required: Financial Modeling Prep API key (screener + portfolio rebalance price history)
FMP_API_KEY=your_api_key_here

